{
  "services": [
    {
      "type": "app",
      "data": {
        "projectName": "designstudio",
        "serviceName": "fbr-designstudio",
        "source": {
          "type": "github",
          "github": {
            "owner": "sergiomvj",
            "repo": "designstudio",
            "branch": "main",
            "path": "/",
            "autoDeploy": true
          }
        },
        "build": {
          "type": "dockerfile",
          "dockerfile": "deploy/Dockerfile"
        },
        "env": "NODE_ENV=production\nOD_PORT=80\nOD_BIND_HOST=0.0.0.0\nHOME=/app/.od\nANTHROPIC_API_KEY=\nOPENAI_API_KEY=\nGOOGLE_API_KEY=\nKIMI_API_KEY=\nQWEN_API_KEY=\nDEEPSEEK_API_KEY=\nQODER_API_KEY=\nOPENCODE_API_KEY=\nOPEN_DESIGN_ALLOWED_ORIGINS=",
        "ports": [
          {
            "published": 80,
            "target": 80
          }
        ],
        "mounts": [
          {
            "type": "volume",
            "name": "od_data",
            "mountPath": "/app/.od"
          }
        ]
      }
    }
  ]
}
